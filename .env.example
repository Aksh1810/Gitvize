# ============================================================================
# GitViz — Environment Variables
# ============================================================================

# --- Required for GitHub API ---
# (Optional) GitHub Personal Access Token for higher rate limits
# GITHUB_TOKEN=ghp_your_token_here

# --- AI Configuration ---
# Gemini API key (free tier — recommended default)
# Get one at: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Optional: multiple Gemini keys for automatic rotation on quota/rate limits
# Comma-separated list, e.g. key1,key2,key3
# GEMINI_API_KEYS=

# Provider: "gemini" | "openai" | "anthropic" | "openai-compatible"
# (auto-detected when GEMINI_API_KEY is set)
AI_PROVIDER=openai

# API key for the AI provider
AI_API_KEY=

# Model to use (e.g. gpt-4o, claude-3-5-sonnet-20241022)
AI_MODEL=gpt-4o

# Custom base URL (optional, for OpenAI-compatible APIs)
# AI_BASE_URL=https://api.openai.com/v1

# --- Database ---
# PostgreSQL connection string (required for caching)
# DATABASE_URL=postgresql://user:password@localhost:5432/gitviz

# --- Analytics ---
# PostHog project API key (optional)
# NEXT_PUBLIC_POSTHOG_KEY=phc_your_key_here
# NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
